    </edmx:Reference>
    <edmx:DataServices>
        <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="local">
            <!-- Override Insertable for EvSnapshot — backend BDEF supports create; but RAP managed-UUID
                 sets Insertable=false in metadata. This override restores the Create button in FPM. -->
            <Annotations Target="com.sap.gateway.srvd.dru.sd_simple_ev.v0001.Container/EvSnapshot">
                <Annotation Term="Capabilities.InsertRestrictions">
                    <Record Type="Capabilities.InsertRestrictionsType">
                        <PropertyValue Property="Insertable" Bool="true"/>
                    </Record>
                </Annotation>
            </Annotations>
            <!-- Override Insertable for EvEnRoll — same reason -->
            <Annotations Target="com.sap.gateway.srvd.dru.sd_simple_ev.v0001.Container/EvEnRoll">
                <Annotation Term="Capabilities.InsertRestrictions">
                    <Record Type="Capabilities.InsertRestrictionsType">
                        <PropertyValue Property="Insertable" Bool="true"/>
                    </Record>
                </Annotation>
            </Annotations>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>